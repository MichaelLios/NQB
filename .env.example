# NQB — Alert configuration
# Copy this file to .env and fill in your credentials.
# Only configure the channels you want to use; the others are ignored.

# Discord: paste your Webhook URL (Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=

# Telegram: create a bot via @BotFather, get your chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Gmail example — use an App Password, not your login password)
ALERT_EMAIL_FROM=youraddress@gmail.com
ALERT_EMAIL_TO=destination@example.com
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_SMTP=smtp.gmail.com
ALERT_EMAIL_PORT=587
